*.beam
*.ez
erl_crash.dump

# Gleam build artifacts (one per package; manifest.toml is tracked only for the
# root server package, ignored for the path-dep siblings client/ and shared/).
/server/build
/client/build
/client/.lustre
/client/dist
/shared/build
/client/manifest.toml
/shared/manifest.toml

# Generated client bundle (built from the client package into the server's priv/static)
/server/priv/static/app.js

# Compiled CSS bundle (the tracked source is client/styles/*.scss; bin/build
# compiles it here with Sass)
/server/priv/static/styles/

# Sass toolchain (client stylesheet build)
/client/node_modules

# Playwright (e2e harness)
/e2e/node_modules
/e2e/test-results
/e2e/playwright-report
/e2e/blob-report
/e2e/playwright/.cache
