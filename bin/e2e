#!/usr/bin/env bash
# Run the Playwright e2e suite against its OWN database (tempo_e2e, suffixed per
# git worktree by bin/worktree-db-suffix), kept separate from dev (tempo), the
# gleam suite (tempo_test*), and other checkouts' e2e runs.
#
# Brings tempo_e2e to the demo state, then runs Playwright (which launches the server
# against tempo_e2e itself — see e2e/playwright.config.js):
#   1. ensure the tempo_e2e database exists
#   2. migrate the schema + apply the base cast
#   3. layer the financials demo (timesheets, invoices, payroll) the specs need
#   4. rebuild the Lustre client bundle so Playwright runs against fresh UI
#   5. run Playwright — extra args are forwarded, e.g. `bin/e2e timesheet.spec.js`
set -euo pipefail
cd "$(dirname "$0")/.."

export TEMPO_DB_NAME="tempo_e2e$(bin/worktree-db-suffix)"

bin/ensure-db "$TEMPO_DB_NAME"
bin/migrate
bin/seed
bin/seed-invoices
bin/build

cd e2e && npx playwright test "$@"
