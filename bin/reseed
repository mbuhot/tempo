#!/usr/bin/env bash
# One-shot DESTRUCTIVE full-demo reset: wipe the database and rebuild a rich demo
# state from scratch — WITHOUT tearing down the container —
#   1. bin/db                 (ensure the PG19 container is up and healthy)
#   2. DROP + CREATE DATABASE (recreate the `tempo` database in-place, dropping every
#                              object; WITH (FORCE) evicts open sessions — a running
#                              server's pool just reconnects to the fresh, empty DB
#                              rather than dying on a destroyed container)
#   3. bin/seed               (migrate the schema, then apply the base cast onto the
#                              freshly-emptied DB)
#   4. bin/seed-invoices      (layer the Jan–Jun 2026 financials demo: timesheets,
#                              18 invoices, six monthly payrolls, and the back-dated
#                              promotion that surfaces a payroll variance)
#
# DESTRUCTIVE: this throws away every fact. It is intentionally SEPARATE from bin/up
# (which stays test-clean and never seeds financials): use bin/up for day-to-day dev,
# bin/reseed only when you want to blow everything away and land the full demo story.
# Drops/recreates the database in-place (not `docker compose down -v`), so it is fast
# and leaves the container — and any running server's connection pool — intact.
set -euo pipefail
cd "$(dirname "$0")/.."

echo "==> [1/4] database (PG19) ........ ensuring up + healthy"
bin/db

echo "==> [2/4] reset .................. drop + recreate the tempo database in-place"
docker exec -i tempo-db psql -U tempo -d postgres -v ON_ERROR_STOP=1 \
  -c "DROP DATABASE IF EXISTS tempo WITH (FORCE);" \
  -c "CREATE DATABASE tempo OWNER tempo;"

echo "==> [3/4] migrate + seed ......... schema + base cast"
bin/seed

echo "==> [4/4] financials demo ........ timesheets, invoices, payroll, variance"
bin/seed-invoices

echo "reseed: full demo state ready."
