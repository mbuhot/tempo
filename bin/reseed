#!/usr/bin/env bash
# One-shot DESTRUCTIVE full-demo reset: wipe the database volume and rebuild a rich
# demo state from scratch in a single command —
#   1. docker compose down -v   (DROPS the data volume — every fact is destroyed)
#   2. bin/db                    (start a fresh PG19 and wait until healthy)
#   3. bin/migrate               (apply schema + base seed onto the empty DB)
#   4. bin/seed-invoices         (layer the Jan–Jun 2026 financials demo: timesheets,
#                                 18 invoices, six monthly payrolls, and the back-dated
#                                 promotion that surfaces a payroll variance)
#
# DESTRUCTIVE: this throws away the entire database volume. It is intentionally
# SEPARATE from bin/up (which stays test-clean and never seeds financials): use
# bin/up for day-to-day dev, bin/reseed only when you want to blow everything away
# and land the full demo story.
set -euo pipefail
cd "$(dirname "$0")/.."

echo "==> [1/4] volume .................. wiping (docker compose down -v)"
docker compose down -v

echo "==> [2/4] database (PG19) ........ starting + waiting for healthy"
bin/db

echo "==> [3/4] migrations ............. schema + base seed"
bin/migrate

echo "==> [4/4] financials demo ........ timesheets, invoices, payroll, variance"
bin/seed-invoices

echo "reseed: full demo state ready."
