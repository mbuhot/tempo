#!/usr/bin/env bash
# Run the Gleam test suite (layers 1-4), check formatting, and lint the stylesheet
# design tokens (#26), hand-written .gleam file size, and e2e locator style.
#
# Targets its OWN database (tempo_test, suffixed per git worktree by
# bin/worktree-db-suffix) so the gleam suite never clobbers — and is never clobbered
# by — interactive dev (tempo), the Playwright e2e suite (tempo_e2e*), or another
# checkout's test runs. The suite is effectively read-only (tx-fixture rollbacks),
# so ensure + migrate + base-seed is a one-time idempotent setup; later runs are
# no-ops. An exported TEMPO_DB_NAME wins, so seed-changing work can target a fresh
# database name (bin/seed only seeds an empty database).
set -euo pipefail
cd "$(dirname "$0")/.."

export TEMPO_DB_NAME="${TEMPO_DB_NAME:-tempo_test$(bin/worktree-db-suffix)}"

bin/ensure-db "$TEMPO_DB_NAME"
bin/migrate
bin/seed

( cd server && gleam test && gleam format --check src test )
( cd client && gleam test && gleam format --check src test )
bin/lint-css
bin/lint-file-size
bin/lint-e2e-locators
